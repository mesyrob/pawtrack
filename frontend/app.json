{
  "expo": {
    "name": "PawTrack",
    "slug": "pawtrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pawtrack",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pawtrack.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFBE6"
      },
      "package": "com.pawtrack.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "PawTrack needs access to your photos to set a pet photo.",
          "cameraPermission": "PawTrack needs access to your camera to take a pet photo."
        }
      ]
    ]
  }
}
